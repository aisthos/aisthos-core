# AisthOS Configuration
# Copy this file to .env and fill in your values

# ── LLM Backends ──────────────────────────────────────
# Anthropic Claude API (get key at console.anthropic.com)
ANTHROPIC_API_KEY=sk-ant-your-key-here
CLAUDE_MODEL=claude-haiku-4-5-20251001

# Ollama (local, free — install from ollama.com)
OLLAMA_URL=http://127.0.0.1:11434
OLLAMA_MODEL=aisthos

# GigaChat / Sber (for Russian market — get at developers.sber.ru)
# GIGACHAT_AUTH_KEY=your_base64_auth_key
# GIGACHAT_CLIENT_ID=your_client_id
# GIGACHAT_SCOPE=GIGACHAT_API_PERS
# GIGACHAT_MODEL=GigaChat

# DeepSeek (cheap cloud API — get key at platform.deepseek.com)
# 11x cheaper than Claude. No geographic restrictions.
# DEEPSEEK_API_KEY=sk-your-deepseek-key
# DEEPSEEK_MODEL=deepseek-chat

# ── Server ────────────────────────────────────────────
SERVER_HOST=127.0.0.1
SERVER_PORT=8765

# WebSocket authentication token (set for production)
# WS_AUTH_TOKEN=your-secret-token

# ── Voice ─────────────────────────────────────────────
# TTS voice (edge-tts voices: https://speech.platform.bing.com/consumer/speech/synthesize/readaloud/voices/list)
EDGE_TTS_VOICE=ru-RU-DmitryNeural
EDGE_TTS_RATE=+10%

# ── Emotion Recognition ──────────────────────────────
EMOTION_ENABLED=true
EMOTION_VOICE_BACKEND=simple
EMOTION_TEXT_BACKEND=claude

# ── HuggingFace (for embedding models) ───────────────
# HF_TOKEN=hf_your-token-here
